# Copy to `.env` and adjust for your environment.
# Only variables prefixed with EXPO_PUBLIC_ are available in app code.

# Backend API base URL (no trailing slash)
EXPO_PUBLIC_API_URL=http://127.0.0.1:3333

# Local development targets:
# - iOS Simulator:     http://127.0.0.1:3333
# - Android emulator:  http://10.0.2.2:3333
#                      (or adb reverse tcp:3333 tcp:3333 then use 127.0.0.1)
# - Physical device:   http://YOUR_LAN_IP:3333
# - Production build:  https://api.your-production-domain.com
